# ARTCB Configuration — copy to .env and fill (NEVER commit .env)
ARTCB_DEBUG=true
ARTCB_LOG_LEVEL=DEBUG
ARTCB_LOG_DIR=./logs
ARTCB_REPORTS_DIR=./rapports
ARTCB_DATA_DIR=./data

# Priority A: rule-based (default, validated Phase 1)
ARTCB_ENCODE_MODE=rule-based
ARTCB_LLM_ENABLED=false

# Priority B: IBM Bob LLM (optional — enable after rule-based OK)
# BOB_API_KEY=bob_prod_...
# BOB_API_BASE=https://api.us-east.bob.ibm.com

# Gradium TTS (optional UI voice)
# GRADIUM_API_KEY=gsk_...
# GRADIUM_API_URL=https://api.gradium.ai

# GitHub PAT (optional HTTPS fallback — SSH preferred)
# GITHUB_TOKEN=ghp_...
