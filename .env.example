# ARTCB — copy to .env: cp ENV_A_REMPLIR_ARTCB .env (NEVER commit .env)

ARTCB_DEBUG=true
ARTCB_LOG_LEVEL=DEBUG
ARTCB_LOG_DIR=./logs
ARTCB_REPORTS_DIR=./rapports
ARTCB_DATA_DIR=./data
ARTCB_HOST=127.0.0.1
ARTCB_PORT=8000
ARTCB_ENCODE_MODE=rule-based
ARTCB_LLM_ENABLED=false
ARTCB_POL_ALPHA=0.4
ARTCB_POL_BETA=0.3
ARTCB_POL_GAMMA=0.3
ARTCB_POL_THRESHOLD=0.6
ARTCB_DEMO_BOOK_PDF=data/fixtures/wailly_le_roi_de_l_inconnu.pdf
ARTCB_NETWORK=local

# Optional — paste your keys (see ENV_A_REMPLIR_ARTCB for French guide)
# BOB_API_KEY=
# OPENROUTER_API_KEY=
# BOB_API_BASE=https://api.us-east.bob.ibm.com
# BOB_MODEL=ibm/granite-3-8b-instruct
# BOB_TEAM_ID=
# BOB_INSTANCE_ID=
# GRADIUM_API_KEY=
# GRADIUM_API_URL=https://api.gradium.ai
# GITHUB_TOKEN=
